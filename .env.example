# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_64_char_hex_secret_here

# ── Environment ───────────────────────────────────────────────────────────────
# Set to "production" on server. Dev mode enables fallback credentials.
NODE_ENV=development

# ── Extension Security (optional but recommended) ─────────────────────────────
# Restrict CORS to your specific Chrome extension ID.
# Find it at chrome://extensions after loading the extension unpacked.
# Leave blank to allow any extension (dev only).
EXTENSION_ID=
