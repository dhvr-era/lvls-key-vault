# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_64_char_hex_secret_here

# Separate encryption key for TOTP seeds (independent of JWT_SECRET)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENC_SECRET=your_64_char_hex_totp_secret_here

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
HOST=127.0.0.1

# ── Extension Security (optional but recommended) ─────────────────────────────
# Restrict CORS to your specific Chrome extension ID.
# Find it at chrome://extensions after loading the extension unpacked.
# Leave blank to allow any extension origin (not recommended for production).
EXTENSION_ID=
