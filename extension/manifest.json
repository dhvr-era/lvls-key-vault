{
  "manifest_version": 3,
  "name": "lvls Key Vault",
  "version": "1.0.0",
  "description": "Auto-fill credentials from lvls Key Vault with level-based auth + TOTP",
  "permissions": ["activeTab", "storage", "tabs", "scripting"],
  "host_permissions": ["http://localhost:3000/*", "<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "lvls Key Vault"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  }
}
